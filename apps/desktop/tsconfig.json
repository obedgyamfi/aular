{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "preserve",
    "jsxImportSource": "solid-js",
    "types": [
      "vite/client"
    ],
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "skipLibCheck": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "~/*": [
        "./src/*"
      ],
      "@dicebear/core": [
        "../../node_modules/@dicebear/core/lib/index.d.ts"
      ],
      "@dicebear/collection": [
        "../../node_modules/@dicebear/collection/lib/index.d.ts"
      ]
    }
  },
  "include": [
    "src"
  ]
}