{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capabilities of the main AULAR window. Deliberately minimal: the webview may talk to the bundled backend sidecar and nothing else.",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "core:window:allow-start-dragging",
    "core:window:allow-minimize",
    "core:window:allow-toggle-maximize",
    "core:window:allow-close",
    "shell:allow-execute",
    {
      "identifier": "shell:allow-spawn",
      "allow": [
        {
          "name": "binaries/aular-core",
          "sidecar": true
        }
      ]
    },
    "core:webview:allow-set-webview-zoom",
    "shell:allow-open"
  ]
}